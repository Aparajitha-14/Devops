pipeline {
    agent any

    tools {
        nodejs 'NodeJS'  // Must match Jenkins Tool configuration
    }

    environment {
        // Prevent Next.js telemetry during CI
        NEXT_TELEMETRY_DISABLED = '1'

        // Dummy MongoDB URI for Next.js build
        MONGODB_URI = 'mongodb://localhost:27017/dummy'

        // Keep existing PATH and add Python
        PATH = "${env.PATH};C:\\Python312;C:\\Python312\\Scripts"
    }

    stages {

        // ──────────────────────────────────────────────
        // 1. Checkout
        // ──────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ──────────────────────────────────────────────
        // 2. Frontend – Install Dependencies
        // ──────────────────────────────────────────────
        stage('Frontend - Install') {
            steps {
                bat 'npm ci'
            }
        }

        // ──────────────────────────────────────────────
        // 3. Frontend – Lint
        // ──────────────────────────────────────────────
        stage('Frontend - Lint') {
            steps {
                bat 'npm run lint'
            }
        }

        // ──────────────────────────────────────────────
        // 4. Frontend – Build
        // ──────────────────────────────────────────────
        stage('Frontend - Build') {
            steps {
                bat 'if exist .next rmdir /s /q .next'
                bat 'npx next build --webpack'
            }
        }

        // ──────────────────────────────────────────────
        // 5. Backend – Test
        // ──────────────────────────────────────────────
        stage('Backend - Test') {
            environment {
                DATABASE_URL = 'sqlite://'
            }

            steps {
                dir('Storeroom backend') {
                    bat '''
                        python -m venv venv
                        call venv\\Scripts\\activate
                        pip install -r requirements.txt
                        pytest --junitxml=..\\test-results\\backend.xml -v
                    '''
                }
            }

            post {
                always {
                    junit allowEmptyResults: true, testResults: 'test-results/backend.xml'
                }
            }
        }

        // ──────────────────────────────────────────────
        // 6. Backend – Docker Build
        // ──────────────────────────────────────────────
        stage('Backend - Docker Build') {
            steps {
                dir('Storeroom backend') {
                    bat 'docker-compose build'
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }

        failure {
            echo '❌ Pipeline failed. Check the logs above for details.'
        }

        always {
            cleanWs()
        }
    }
}